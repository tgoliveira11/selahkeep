{
  "name": "letters-to-god",
  "version": "0.3.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "predev": "node scripts/copy-ffmpeg.mjs",
    "build": "next build",
    "prebuild": "node scripts/copy-ffmpeg.mjs",
    "start": "next start",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:coverage",
    "test:watch": "vitest",
    "validate": "npm run lint && npm run typecheck && npm run test:coverage && AUTH_RATE_LIMIT_STORE=postgres RATE_LIMIT_STORE=postgres npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check-auth": "node scripts/check-auth-db.mjs",
    "db:check-kanban": "node scripts/check-kanban-db.mjs",
    "db:check-vault-admin": "node scripts/check-vault-admin-db.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "postinstall": "mkdir -p public/swagger-ui && cp node_modules/swagger-ui-dist/swagger-ui.css node_modules/swagger-ui-dist/swagger-ui-bundle.js public/swagger-ui/ && node scripts/copy-ffmpeg.mjs"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@huggingface/transformers": "^3.8.1",
    "@scure/bip39": "^1.6.0",
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "@tgoliveira/outpost": "^1.2.0",
    "@tgoliveira/secure-auth": "0.5.0",
    "@tgoliveira/vault-core": "^1.0.0",
    "@tiptap/extension-link": "^3.27.0",
    "@tiptap/extension-placeholder": "^3.27.0",
    "@tiptap/extension-task-item": "^3.27.0",
    "@tiptap/extension-task-list": "^3.27.0",
    "@tiptap/pm": "^3.27.0",
    "@tiptap/react": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0",
    "drizzle-orm": "^0.45.2",
    "hash-wasm": "^4.12.0",
    "idb": "^8.0.2",
    "marked": "^18.0.5",
    "mediabunny": "^1.49.0",
    "next": "^16.2.9",
    "next-auth": "^4.24.11",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sanitize-html": "^2.17.1",
    "swagger-ui-dist": "^5.11.0",
    "tiptap-markdown": "^0.9.0",
    "uuid": "^11.1.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.15.29",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/sanitize-html": "^2.16.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "axe-core": "^4.12.1",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.9",
    "happy-dom": "^20.10.4",
    "jest-axe": "^10.0.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.10",
    "next-auth": {
      "uuid": "$uuid",
      "nodemailer": "$nodemailer"
    }
  }
}
