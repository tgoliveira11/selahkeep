DATABASE_URL=postgresql://letters:letters_dev@localhost:5435/letters_to_god
APP_NAME="Letters to God"
APP_SLUG=letters-to-god
APP_BASE_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
AUTH_AFTER_LOGIN_PATH=/letters
AUTH_AFTER_LOGOUT_PATH=/login

# Account 2FA — encrypt TOTP secrets at rest (generate: openssl rand -base64 32)
TWO_FACTOR_SECRET_ENCRYPTION_KEY=change-me-in-production-use-openssl-rand-base64-32

# OAuth (optional for local dev) — AUTH_* names preferred; legacy names still supported
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_APPLE_CLIENT_ID=
AUTH_APPLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Microsoft sign-in (NextAuth Azure AD provider — account authentication only)
# Provider ID: azure-ad → callback http://localhost:3001/api/auth/callback/azure-ad
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_TENANT_ID=common
AUTH_AZURE_AD_ID=
AUTH_AZURE_AD_SECRET=
AUTH_AZURE_AD_TENANT_ID=common

# WebAuthn (local dev defaults — port 3001)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Letters to God
WEBAUTHN_ORIGIN=http://localhost:3001

# Sessions
AUTH_SESSION_MAX_AGE_SECONDS=2592000
AUTH_SESSION_LAST_USED_UPDATE_SECONDS=300
AUTH_SINGLE_ACTIVE_SESSION=false
AUTH_SESSION_REVOCATION_POLL_SECONDS=10

# Rate limiting: memory (local/test) or postgres (production multi-instance)
AUTH_RATE_LIMIT_STORE=memory
RATE_LIMIT_STORE=memory

# Cookies (unset = secure in production, non-secure in development)
AUTH_COOKIE_SECURE=

# Email verification
EMAIL_VERIFICATION_SEND_ON_REGISTER=true
EMAIL_VERIFICATION_REQUIRE_BEFORE_SIGN_IN=false

# Debug
AUTH_TRACE=false

# Package health (after dev server is running):
# curl http://localhost:3001/api/auth/package-health

# Email — console (local debug) | smtp (Mailpit, Brevo, etc.) | resend | sendgrid
# Never use EMAIL_PROVIDER=console in production.
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@localhost
APP_BASE_URL=http://localhost:3001

# SMTP (when EMAIL_PROVIDER=smtp)
# Local Mailpit (docker compose up -d mailpit — UI http://localhost:8025):
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM="Letters to God <noreply@localhost>"
#
# Staging Brevo example (do not commit real credentials):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=<brevo-smtp-login>
# SMTP_PASSWORD=<brevo-smtp-key>
# EMAIL_FROM="Letters to God <noreply@yourdomain.com>"
# APP_BASE_URL=https://your-staging-url
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Account session last-used DB write throttle (seconds) — legacy name; prefer AUTH_SESSION_LAST_USED_UPDATE_SECONDS
SESSION_LAST_USED_UPDATE_INTERVAL_SECONDS=300

# Password policy (off | warn | enforce) — AUTH_* names preferred; package default min length is 12
# Set AUTH_PASSWORD_MIN_LENGTH (or PASSWORD_MIN_LENGTH) once; all secure-auth password flows use it (1–128).
AUTH_PASSWORD_POLICY_ENFORCEMENT=warn
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_UPPERCASE=false
AUTH_PASSWORD_REQUIRE_LOWERCASE=false
AUTH_PASSWORD_REQUIRE_NUMBER=false
AUTH_PASSWORD_REQUIRE_SYMBOL=false
AUTH_PASSWORD_BLOCK_COMMON_PASSWORDS=true
AUTH_PASSWORD_MIN_SCORE=2
AUTH_PASSWORD_STRENGTH_POSITION=above
PASSWORD_POLICY_ENFORCEMENT=warn
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_LOWERCASE=false
PASSWORD_REQUIRE_NUMBER=false
PASSWORD_REQUIRE_SYMBOL=false
PASSWORD_BLOCK_COMMON_PASSWORDS=true
PASSWORD_MIN_SCORE=2

# Optional
# MAX_TRUSTED_DEVICES=50

# Show Swagger UI at /api-docs in production (disabled by default)
# ENABLE_API_DOCS=true
